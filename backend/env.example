# Backend HTTP port (used by src/config/env.ts)
PORT=3000

# Application version for logging metadata
APP_VERSION=0.0.1

# Comma-separated trusted origins for CORS and Better Auth
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3100

# Better Auth runtime configuration
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Prisma/PostgreSQL connection string
DATABASE_URL=postgresql://postgres@localhost:5433/betterauth?schema=public
